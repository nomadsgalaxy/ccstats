# Replaces the pre-1.2.1 root cron "extract.py --mode competitor" (every 2 min).
# Odd minutes (see the timer) so the fresh limits reading from ccstats-usage
# (even minutes) is already on disk.

[Unit]
Description=ccstats — refresh the head-to-head competition feed
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/bin/python3 @OPT@/extract.py --mode competitor --server @SERVER@ --ledger @OPT@/ledger.db --config @OPT@/config.json --limits-file @WEB@/claude-limits.json --bottleneck-db @OPT@/bottleneck.db --peers-dir @WEB@/peers --output @WEB@/competitor.json --competition-output @WEB@/competition.json
User=ccollector
Group=ccollector
UMask=0022
WorkingDirectory=@OPT@
StandardOutput=append:/var/log/ccstats/competitor.log
StandardError=append:/var/log/ccstats/competitor.log
NoNewPrivileges=yes
CapabilityBoundingSet=CAP_DAC_READ_SEARCH
AmbientCapabilities=CAP_DAC_READ_SEARCH
ProtectSystem=strict
ProtectHome=tmpfs
ReadWritePaths=@OPT@ @WEB@ /var/log/ccstats
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
LockPersonality=yes
RestrictNamespaces=yes
SystemCallArchitectures=native
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
