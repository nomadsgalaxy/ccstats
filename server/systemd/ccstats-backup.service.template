# On-demand restore-point snapshot (consistent SQLite online backup + config/
# token copies). Triggered by deploy.sh before code updates — including
# non-root deploys, which start it via scoped sudo. No timer by design.

[Unit]
Description=ccstats — take a timestamped restore-point snapshot

[Service]
Type=oneshot
ExecStart=/usr/bin/python3 @OPT@/extract.py --mode backup --ledger @OPT@/ledger.db --bottleneck-db @OPT@/bottleneck.db --config @OPT@/config.json --backups-dir @OPT@/backups
User=ccollector
Group=ccollector
UMask=0022
WorkingDirectory=@OPT@
StandardOutput=append:/var/log/ccstats/extract.log
StandardError=append:/var/log/ccstats/extract.log
NoNewPrivileges=yes
CapabilityBoundingSet=CAP_DAC_READ_SEARCH
AmbientCapabilities=CAP_DAC_READ_SEARCH
ProtectSystem=strict
ProtectHome=tmpfs
ReadWritePaths=@OPT@ @WEB@ /var/log/ccstats
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
LockPersonality=yes
RestrictNamespaces=yes
SystemCallArchitectures=native
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
