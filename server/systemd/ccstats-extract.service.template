# Replaces the pre-1.2.1 root cron "extract.py --mode full" (every 5 min).
# Runs as 'ccollector'; CAP_DAC_READ_SEARCH reads users' 0600 transcripts.
# Triggered by ccstats-extract.timer, or manually: systemctl start ccstats-extract

[Unit]
Description=ccstats — parse transcripts into the ledger and publish claude-stats.json
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/bin/python3 @OPT@/extract.py --mode full --server @SERVER@ --fragments-dir @WEB@/fragments --output @WEB@/claude-stats.json
User=ccollector
Group=ccollector
UMask=0022
WorkingDirectory=@OPT@
StandardOutput=append:/var/log/ccstats/extract.log
StandardError=append:/var/log/ccstats/extract.log
NoNewPrivileges=yes
CapabilityBoundingSet=CAP_DAC_READ_SEARCH
AmbientCapabilities=CAP_DAC_READ_SEARCH
ProtectSystem=strict
ProtectHome=tmpfs
ReadWritePaths=@OPT@ @WEB@ /var/log/ccstats
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
LockPersonality=yes
RestrictNamespaces=yes
SystemCallArchitectures=native
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
