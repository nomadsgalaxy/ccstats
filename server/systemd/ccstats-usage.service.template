# Replaces the pre-1.2.1 root cron for usage-monitor.py (every 2 min).
# CAP_DAC_READ_SEARCH reads users' 0600 ~/.claude/.credentials.json (the poller
# never refreshes tokens — that's Claude Code's job).

[Unit]
Description=ccstats — poll session/weekly limits and publish claude-limits.json
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/bin/python3 @OPT@/usage-monitor.py --output @WEB@/claude-limits.json --merge-dir @WEB@/limits-remote
User=ccollector
Group=ccollector
UMask=0022
WorkingDirectory=@OPT@
StandardOutput=append:/var/log/ccstats/usage.log
StandardError=append:/var/log/ccstats/usage.log
NoNewPrivileges=yes
CapabilityBoundingSet=CAP_DAC_READ_SEARCH
AmbientCapabilities=CAP_DAC_READ_SEARCH
ProtectSystem=strict
ProtectHome=tmpfs
ReadWritePaths=@OPT@ @WEB@ /var/log/ccstats
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
LockPersonality=yes
RestrictNamespaces=yes
SystemCallArchitectures=native
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
